<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Marcus’s GUI - Personal Proxy 🚀</title>
  <link rel="stylesheet" href="style.css"/>
</head>
<body>
  <div class="container">
    <h1>Marcus’s GUI</h1>
    <p>Unblock sites, games, and more – your way.</p>

    <div class="search-box">
      <input type="text" id="urlInput" placeholder="Enter URL (e.g. https://youtube.com)" autocomplete="off"/>
      <button onclick="proxyGo()">Launch</button>
    </div>

    <div class="tabs">
      <button class="tab active" onclick="showTab('proxy')">Proxy</button>
      <button class="tab" onclick="showTab('games')">Games</button>
    </div>

    <div id="proxy" class="tab-content active">
      <iframe id="proxyFrame" sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-modals" style="display:none; width:100%; height:80vh; border:none;"></iframe>
    </div>

    <div id="games" class="tab-content" style="display:none;">
      <p>Coming soon – add your favorite embedded games here!</p>
      <!-- Example: <iframe src="https://thisismyproxygame.com/embed" width="100%" height="500"></iframe> -->
    </div>

    <footer>Made by Marcus  • 2026</footer>
  </div>

  <script src="script.js"></script>
  <script>
    // Register service worker for better proxying
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js')
        .then(reg => console.log('Marcus’s GUI SW registered!', reg))
        .catch(err => console.log('SW failed:', err));
    }
  </script>
</body>
</html>
